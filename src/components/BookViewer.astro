---
// BookViewer — a paged book spread viewer.
//
// Reading model:
//   - Spread 1: front cover on the RIGHT, left page empty (no left arrow)
//   - Spreads 2..N-1: interior page pairs (left + right, both arrows)
//   - Spread N: back cover on the LEFT, right page empty (no right arrow)
//
// Interaction:
//   - Prev / Next buttons (hidden when there's no neighbour, e.g. left arrow
//     is hidden on the cover spread).
//   - Keyboard ← / → when the viewer has focus.
//
// Navigation does NOT animate — spreads swap instantly, like flipping
// through a stack of cards. The viewer is bootstrapped on every Astro
// View Transition so re-entering the project page rewires events.
//
// Usage in MDX:
//   import BookViewer from '../../components/BookViewer.astro';
//   <BookViewer
//     frontCover="/img/book-design/book-front.jpg"
//     backCover="/img/book-design/book-back.jpg"
//     pages={[ '/img/book-design/p01.jpg', '/img/book-design/p02.jpg', ... ]}
//     alt="Book name page"
//   />

interface Props {
  /** Interior page image URLs in reading order. Every two consecutive
   *  entries form one spread (left + right). */
  pages: string[];
  /** Front cover image. If provided, becomes the first spread (right side
   *  only). */
  frontCover?: string;
  /** Back cover image. If provided, becomes the last spread (left side
   *  only). */
  backCover?: string;
  /** Alt-text prefix used for every page image. */
  alt?: string;
  /** ARIA label for the whole viewer region. */
  label?: string;
  /** CSS aspect-ratio of the whole spread (left + right combined).
   *  Defaults to "auto" — the viewer measures the first page image's
   *  natural dimensions and sets the frame to match. Pass an explicit
   *  value (e.g. "2 / 1.414" for A4, "2 / 1.5" for a taller book) to
   *  override the auto-detection. */
  aspectRatio?: string;
}

const {
  pages,
  frontCover,
  backCover,
  alt = 'Book page',
  label = 'Book pages',
  aspectRatio = 'auto',
} = Astro.props;

// Until JS auto-measures (or if the user explicitly set a ratio), the
// inline style applies. "auto" → use a sensible fallback (A4 spread) so
// the frame has a height before the first image loads, avoiding a
// noticeable layout shift.
const initialAspect = aspectRatio === 'auto' ? '2 / 1.414' : aspectRatio;

type Spread = { left?: string; right?: string; leftAlt?: string; rightAlt?: string };
const spreads: Spread[] = [];

if (frontCover) {
  spreads.push({ right: frontCover, rightAlt: `${alt} — front cover` });
}
for (let i = 0; i < pages.length; i += 2) {
  spreads.push({
    left: pages[i],
    right: pages[i + 1],
    leftAlt: `${alt} ${i + 1}`,
    rightAlt: pages[i + 1] ? `${alt} ${i + 2}` : undefined,
  });
}
if (backCover) {
  spreads.push({ left: backCover, leftAlt: `${alt} — back cover` });
}
---

<div class="book-viewer" data-total={spreads.length} role="region" aria-label={label} tabindex="0">
  <div class="book-stage">
    <button type="button" class="book-nav prev" aria-label="Previous spread">
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path d="M9 1L3 7l6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <div class="book-frame" style={`aspect-ratio: ${initialAspect}`} data-auto-aspect={aspectRatio === 'auto' ? '' : null}>
      {spreads.map((s, i) => (
        <div class={`book-spread${i === 0 ? ' is-active' : ''}`} data-index={i}>
          <div class={`book-page left${s.left ? '' : ' is-empty'}`}>
            {s.left && (
              <img
                src={s.left}
                alt={s.leftAlt ?? ''}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                draggable="false"
              />
            )}
          </div>
          <div class={`book-page right${s.right ? '' : ' is-empty'}`}>
            {s.right && (
              <img
                src={s.right}
                alt={s.rightAlt ?? ''}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                draggable="false"
              />
            )}
          </div>
        </div>
      ))}
    </div>

    <button type="button" class="book-nav next" aria-label="Next spread">
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path d="M5 1l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>

</div>

<style>
  .book-viewer {
    width: 100%;
    max-width: 1000px;
    margin: 2.5rem auto;
    user-select: none;
    outline: none;
  }

  .book-stage {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* The book frame is the visible double-page area. Spreads stack on top
     of each other; only the active one is `display: grid`.
     - No shadow (empty cover/back-cover pages would show a "floating"
       shadow under nothing)
     - No border here — moved to .book-page so empty halves of the
       cover/back-cover spreads have nothing around them
     - aspect-ratio is set inline from the `aspectRatio` prop so each
       book can match its own proportions */
  .book-frame {
    flex: 1;
    position: relative;
    border-radius: 2px;
  }

  .book-spread {
    position: absolute;
    inset: 0;
    display: none;
    grid-template-columns: 1fr 1fr;
  }
  .book-spread.is-active { display: grid; }

  /* Each page carries its own 1px border so all-white pages still read
     as part of a book. When two real pages sit next to each other, the
     two touching borders form the spine line. When a cover-only spread
     has an empty side, that empty side has NO border / no background
     (see .book-page.is-empty below) so the cover looks like a single
     page floating on the website. */
  .book-page {
    background: #fff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 0, 0, 0.12);
  }
  .book-page img {
    width: 100%;
    height: 100%;
    /* `contain` shows the whole page (no cropping). If the image's
       natural aspect doesn't match the frame, the surrounding space
       stays white — matches the look of a blank book margin. */
    object-fit: contain;
    display: block;
    pointer-events: none;
    /* Project pages set `.project-content img { opacity: 0 }` until a
       scroll-reveal observer adds `.visible`. Book pages handle their
       own visibility, so opt out of that global animation here. */
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
    margin: 0 !important;
    max-width: none !important;
  }
  /* Empty halves of the cover / back-cover spreads — fully transparent,
     no border, so the visible page next to them looks like a single
     standalone book cover (not half of an open spread). */
  .book-page.is-empty {
    background: transparent;
    border: none;
  }

  .book-nav {
    flex: 0 0 auto;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: #fff;
    color: #222;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      opacity 0.2s ease,
      border-color 0.2s ease;
  }
  .book-nav:hover:not(:disabled) {
    background: #f5f5f5;
    transform: scale(1.06);
  }
  /* Hidden (not just disabled) at the ends so it visually reads "this is
     the cover / back" — nothing to flip back/forward to. visibility:hidden
     keeps the layout from shifting when arrows appear/disappear. */
  .book-nav.is-hidden { visibility: hidden; }
  .book-nav svg { display: block; }

  /* Dark-mode tweaks. */
  :global([data-theme='dark']) .book-nav {
    background: var(--surface, #161616);
    color: var(--fg, #f4f4f4);
    border-color: var(--border, rgba(255, 255, 255, 0.15));
  }
  :global([data-theme='dark']) .book-nav:hover:not(:disabled) {
    background: var(--surface-alt, #1f1f1f);
  }
  :global([data-theme='dark']) .book-page { border-color: rgba(255, 255, 255, 0.18); }

  @media (max-width: 640px) {
    .book-stage { gap: 0.35rem; }
    .book-nav { width: 36px; height: 36px; }
    .book-viewer { margin: 1.5rem auto; }
  }
</style>

<script>
  // Bootstrap every BookViewer on the page. Re-runs after Astro View
  // Transitions so navigating back to a book page rewires events.
  let bookAbort: AbortController | null = null;

  function bootstrapBookViewers() {
    if (bookAbort) bookAbort.abort();
    const viewers = document.querySelectorAll<HTMLElement>('.book-viewer');
    if (!viewers.length) return;
    bookAbort = new AbortController();
    const { signal } = bookAbort;

    viewers.forEach((viewer) => {
      const spreads = Array.from(viewer.querySelectorAll<HTMLElement>('.book-spread'));
      const prev = viewer.querySelector<HTMLButtonElement>('.book-nav.prev');
      const next = viewer.querySelector<HTMLButtonElement>('.book-nav.next');
      const frame = viewer.querySelector<HTMLElement>('.book-frame');
      const total = spreads.length;
      if (!total) return;

      // Auto-fit: when the frame has [data-auto-aspect], measure the
      // first page image's natural dimensions and set
      //   aspect-ratio: (2 × pageWidth) / pageHeight
      // so the spread exactly matches the book's proportions
      // (works for A4, A5, Letter, square — whatever the file is).
      if (frame && frame.dataset.autoAspect !== undefined) {
        const firstImg = viewer.querySelector<HTMLImageElement>('.book-page img');
        const applyAuto = () => {
          if (!firstImg) return;
          const w = firstImg.naturalWidth;
          const h = firstImg.naturalHeight;
          if (w && h) frame.style.aspectRatio = `${2 * w} / ${h}`;
        };
        if (firstImg?.complete && firstImg.naturalWidth) {
          applyAuto();
        } else {
          firstImg?.addEventListener('load', applyAuto, { once: true, signal });
        }
      }

      let index = 0;

      const update = () => {
        spreads.forEach((s, i) => s.classList.toggle('is-active', i === index));
        // Hide (not just disable) arrows at the ends so it reads "no
        // previous page" / "no next page" visually.
        if (prev) prev.classList.toggle('is-hidden', index === 0);
        if (next) next.classList.toggle('is-hidden', index >= total - 1);
      };
      const go = (to: number) => {
        index = Math.max(0, Math.min(total - 1, to));
        update();
      };

      prev?.addEventListener('click', () => go(index - 1), { signal });
      next?.addEventListener('click', () => go(index + 1), { signal });

      // Keyboard navigation when the viewer itself has focus.
      viewer.addEventListener(
        'keydown',
        (e) => {
          if (e.key === 'ArrowLeft') { go(index - 1); e.preventDefault(); }
          if (e.key === 'ArrowRight') { go(index + 1); e.preventDefault(); }
        },
        { signal },
      );

      update();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootstrapBookViewers, { once: true });
  } else {
    bootstrapBookViewers();
  }
  document.addEventListener('astro:after-swap', bootstrapBookViewers);
</script>
