---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/about.css';

const breadcrumbJsonLd = `<script type="application/ld+json">${JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://wangyifan-design.com/" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://wangyifan-design.com/about/" }
  ]
})}<\/script>`;

const research = [
  {
    name: 'Human–Machine Collaborative Design',
    detail: 'I study how AI participates in visual creation, design decision-making, and professional workflows.',
  },
  {
    name: 'Cultural Interfaces & Chinese Visual Systems',
    detail: 'I explore Chinese characters, traditional symbols, and cultural memory as living design systems in contemporary media.',
  },
  {
    name: 'Speculative AI Art & Design Philosophy',
    detail: 'I use AI as a medium to investigate materiality, memory, authorship, and the boundary between human imagination and machine generation.',
  },
];

const experience = [
  { role: 'Product Designer, Rockhood.ai', time: 'Feb 2025 – Now', detail: 'Leading brand, UI, and product design for an AI-powered conversational real estate platform.' },
  { role: 'UX Designer, Tsinghua Future Lab', time: '2024 – Now',   detail: 'Designed user journey maps and AI tools for senior care and natural language interaction.' },
  { role: 'Design Intern, Baidu / Alibaba / SenseTime', detail: 'Explored large-scale product systems and AI-driven interfaces across different industry contexts. Gained experience working within cross-functional teams and understanding real-world design constraints.' },
];

const education = [
  { role: 'PhD in Visual Communication', time: '2020 – 2024, Tsinghua University', detail: 'Research in intelligent design, ancient character innovation, and speculative AI interfaces.' },
  { role: 'MA in Visual Communication',  time: '2016 – 2019, Tsinghua University', detail: 'Focus on revitalizing traditional culture through virtual exhibitions and visual systems.' },
  { role: 'BA in Visual Communication',  time: '2012 – 2016, Tsinghua University', detail: 'Trained in fundamental design skills: logo design, typography, packaging, and motion graphics.' },
];

const publications = [
  {
    name: 'Transformation with AI: Zhuangzi’s “Wuhua” Theory Inspires AI-Generated Art Development',
    time: '2026, Thinking Skills and Creativity (Elsevier) · with H. Yang and U. Amnueypol',
    link: 'https://doi.org/10.1016/j.tsc.2026.102239',
  },
  {
    name: 'Covered with AI: The Speculative Design (AI包浆：一种思辨性设计)',
    time: '2024, Chinese Art 《中国艺术》, 2024(3) · with Jiang Xiangwei',
  },
  {
    name: 'How Artificial Intelligence Is Affecting Logo Design (人工智能对标志设计的影响)',
    time: '2024, Design 《设计》, 37(9)',
    link: 'https://doi.org/10.20055/j.cnki.1003-0069.001749',
  },
  {
    name: 'Harmonizing with Machines: Development and Challenges of Human-Machine Collaborative Design (与机器共鸣：人机协同设计的发展与挑战)',
    time: '2024, Design Research 《设计艺术研究》, 14(5): 11–16',
  },
  {
    name: 'Research on the Application and Impact of Artificial Intelligence in Visual Communication Design (人工智能在视觉传达设计中的应用与影响研究)',
    time: '2024, PhD Dissertation, Tsinghua University · Advisor: Prof. Chen Nan',
  },
  {
    name: 'Creating Cultural Sculpture: Analyzing the Value of Traditional Chinese Sculpture Based on the Five Levels of Human Cognition',
    time: '2023, International Journal of Arts Theory & History, 18(2): 21–42 · with H. Yang and U. Amnueypol',
    link: 'https://doi.org/10.18848/2326-9952/CGP/v18i02/21-42',
  },
  {
    name: 'Design Philosophy Under the Compulsion of Technology: Materiality, Holism, and Creativity (技术促逼下的设计哲学：物质性、整体性、创造力)',
    time: '2023, Journal of Oriental Design 《东方设计学报》, 3(4): 83–87',
  },
  {
    name: 'Virtual Zoo Design Based on Animal Imagery in Traditional Chinese Culture (基于中国传统文化中动物形象研究的虚拟动物园设计)',
    time: '2019, Master’s Thesis, Tsinghua University · Advisor: Prof. Chen Nan',
  },
];

const conferencePresentations: { name: string; time: string; link?: string }[] = [
  {
    name: '“Visualization of Dreams: An Analysis of Artificial Intelligence in Surrealist Art Creation” (presentation proposal)',
    time: '2024, Nineteenth International Conference on the Arts in Society · Hanyang University, Seoul, South Korea + Online · May 24–26, 2024',
  },
];

const exhibitions = [
  { name: 'National Graphic Design Exhibition (Selected / Finalist)', time: '2025, China Artists Association' },
  { name: 'Tianjin Youth Art Season (Selected Work)', time: '2025, Tianjin Academy of Fine Arts' },
  { name: 'Moments in Sound and Image - Tsinghua Alumni Boston Art Festival', link: 'https://www.tsinghua.org.cn/info/1013/41767.htm', time: '2025, North America Federation of Tsinghua Alumni Association' },
  { name: 'Chinese Character Interactive Festival', time: '2022, Macao' },
];

const awards = [
  { name: 'Shenzhen Global Design Award (Excellence Award / Kunpeng Award)', time: '2024, Shenzhen Municipal Government / Shenzhen Innovation & Creative Design Development Office' },
  { name: 'BIAF Busan International Art Festival (Silver Award)', time: '2024, Busan Metropolitan City / BIAF Organizing Committee' },
  { name: 'Asia Vanguard Art and Design Competition / 亚洲新锐艺术与设计大赛 AVADC (First Prize)', time: '2024' },
];

const activities = [
  { name: 'GDC Show 2017 — Tell the Future (Execution Team)', link: 'https://www.gdcaward.com/gdc-show-243.html?lang=cn', time: '2017, Tsinghua University' },
  { name: 'Tsinghua International Art & Design Education Conference (Volunteer)', time: '2023, Tsinghua University' },
];

const photoStripImages = [1, 2, 3, 4, 5, 6].map(n => `/img/strip/strip-${n}.jpg`);
---

<BaseLayout
  title="About Wang Yifan | Visual & UX Designer"
  description="Learn about Wang Yifan, a visual and UX designer with deep experience in intelligent design systems, research, and interactive storytelling."
  ogType="profile"
  pageType="default"
  extraHead={breadcrumbJsonLd}
>
  <section class="about-intro">
    <h1>About Me</h1>
    <p>
      I am a visual communication designer and researcher working at the intersection of artificial intelligence,
      visual systems, and cultural imagination. With a Ph.D. in Visual Communication from Tsinghua University, my
      work explores how intelligent technologies reshape design authorship, human–machine collaboration, and the
      contemporary expression of traditional visual culture.
    </p>
  </section>

  <section class="photo-strip-wrapper">
    <div class="photo-strip">
      {photoStripImages.map((src) => (
        <img src={src} alt="Wang Yifan at work" />
      ))}
      {/* Duplicate for continuous scrolling */}
      {photoStripImages.map((src) => (
        <img src={src} alt="" aria-hidden="true" />
      ))}
    </div>
  </section>

  <section class="about-text">
    <div class="about-sections">
      <div class="about-section">
        <h2 class="no-scramble">Research &amp; Creative Practice</h2>
        <ul class="about-list">
          {research.map((it) => (
            <li>
              <div>{it.name}</div>
              <div>{it.detail}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Selected Experience</h2>
        <ul class="about-list">
          {experience.map((it) => (
            <li>
              <div>{it.role}</div>
              {it.time && <div class="meta">{it.time}</div>}
              <div>{it.detail}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Education</h2>
        <ul class="about-list">
          {education.map((it) => (
            <li>
              <div>{it.role}</div>
              <div class="meta">{it.time}</div>
              <div>{it.detail}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Publications</h2>
        <ul class="about-list">
          {publications.map((it) => (
            <li>
              <div>
                {it.link
                  ? <a href={it.link} target="_blank" rel="noopener noreferrer" class="inline-link">{it.name}</a>
                  : it.name}
              </div>
              <div class="meta">{it.time}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Conference Presentations</h2>
        <ul class="about-list">
          {conferencePresentations.map((it) => (
            <li>
              <div>
                {it.link
                  ? <a href={it.link} target="_blank" rel="noopener noreferrer" class="inline-link">{it.name}</a>
                  : it.name}
              </div>
              <div class="meta">{it.time}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Exhibitions</h2>
        <ul class="about-list">
          {exhibitions.map((it) => (
            <li>
              <div>
                {it.link
                  ? <a href={it.link} target="_blank" rel="noopener noreferrer" class="inline-link">{it.name}</a>
                  : it.name}
              </div>
              <div class="meta">{it.time}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Awards</h2>
        <ul class="about-list">
          {awards.map((it) => (
            <li>
              <div>{it.name}</div>
              <div class="meta">{it.time}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="about-section">
        <h2 class="no-scramble">Activities</h2>
        <ul class="about-list">
          {activities.map((it) => (
            <li>
              <div>
                {it.link
                  ? <a href={it.link} target="_blank" rel="noopener noreferrer" class="inline-link">{it.name}</a>
                  : it.name}
              </div>
              <div class="meta">{it.time}</div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
