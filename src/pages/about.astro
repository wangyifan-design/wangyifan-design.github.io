---
import BaseLayout from '../layouts/BaseLayout.astro';
import DogHero from '../components/DogHero.astro';
import '../styles/about.css';
import '../styles/dog.css';

const breadcrumbJsonLd = `<script type="application/ld+json">${JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://wangyifan-design.com/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://wangyifan-design.com/about/' },
  ],
})}<\/script>`;

const practice = [
  {
    name: 'Human–Machine Collaboration',
    detail: 'I study how AI can participate thoughtfully in creative decisions, visual production, and everyday professional workflows.',
    href: '/projects/rockhood/',
    linkLabel: 'View Rockhood.ai',
  },
  {
    name: 'Cultural Visual Systems',
    detail: 'I reinterpret Chinese characters, traditional symbols, and cultural memory as living systems for contemporary experiences.',
    href: '/projects/livingjiagu/',
    linkLabel: 'View Living Jiagu',
  },
  {
    name: 'Speculative AI Design',
    detail: 'I use AI as a medium to explore materiality, memory, authorship, and the changing boundary between people and machines.',
    href: '/projects/heidegger/',
    linkLabel: 'View Heidegger’s Hammer',
  },
];

const experience = [
  {
    title: 'Product Designer',
    organization: 'Rockhood.ai',
    period: 'Feb 2025–Present',
    detail: 'Leading brand, interface, and product design for an AI-powered conversational real estate platform.',
  },
  {
    title: 'UX Designer',
    organization: 'Tsinghua Future Lab',
    period: '2024–Present',
    detail: 'Designing user journeys and AI tools for senior care and natural-language interaction.',
  },
  {
    title: 'Design Intern',
    organization: 'Baidu · Alibaba · SenseTime',
    detail: 'Explored large-scale product systems and AI-driven interfaces across cross-functional teams and industry contexts.',
  },
];

const education = [
  {
    degree: 'PhD, Visual Communication',
    school: 'Tsinghua University',
    period: '2020–2024',
    detail: 'Research in intelligent design, ancient-character innovation, and speculative AI interfaces.',
  },
  {
    degree: 'MA, Visual Communication',
    school: 'Tsinghua University',
    period: '2016–2019',
    detail: 'Focused on revitalizing traditional culture through virtual exhibitions and visual systems.',
  },
  {
    degree: 'BA, Visual Communication',
    school: 'Tsinghua University',
    period: '2012–2016',
    detail: 'Trained in identity, typography, packaging, and motion design.',
  },
];

const publications = [
  {
    name: 'Transformation with AI: Zhuangzi’s “Wuhua” Theory Inspires AI-Generated Art Development',
    meta: 'Thinking Skills and Creativity (Elsevier) · 2026 · with H. Yang and U. Amnueypol',
    link: 'https://doi.org/10.1016/j.tsc.2026.102239',
  },
  {
    name: 'Covered with AI: The Speculative Design',
    meta: 'Chinese Art · Issue 3 · 2024 · with Jiang Xiangwei',
  },
  {
    name: 'How Artificial Intelligence Is Affecting Logo Design',
    meta: 'Design · 37(9) · 2024',
    link: 'https://doi.org/10.20055/j.cnki.1003-0069.001749',
  },
  {
    name: 'Harmonizing with Machines: Development and Challenges of Human–Machine Collaborative Design',
    meta: 'Design Research · 14(5), 11–16 · 2024',
  },
  {
    name: 'Research on the Application and Impact of Artificial Intelligence in Visual Communication Design',
    meta: 'PhD dissertation · Tsinghua University · 2024 · Advisor: Prof. Chen Nan',
  },
  {
    name: 'Creating Cultural Sculpture: Analyzing the Value of Traditional Chinese Sculpture Based on the Five Levels of Human Cognition',
    meta: 'International Journal of Arts Theory & History · 18(2), 21–42 · 2023 · with H. Yang and U. Amnueypol',
    link: 'https://doi.org/10.18848/2326-9952/CGP/v18i02/21-42',
  },
  {
    name: 'Design Philosophy Under the Compulsion of Technology: Materiality, Holism, and Creativity',
    meta: 'Journal of Oriental Design · 3(4), 83–87 · 2023',
  },
  {
    name: 'Virtual Zoo Design Based on Animal Imagery in Traditional Chinese Culture',
    meta: 'Master’s thesis · Tsinghua University · 2019 · Advisor: Prof. Chen Nan',
  },
];

const conferencePresentations = [
  {
    name: 'Visualization of Dreams: An Analysis of Artificial Intelligence in Surrealist Art Creation',
    meta: 'Presentation proposal · Nineteenth International Conference on the Arts in Society · Hanyang University, Seoul + Online · May 24–26, 2024',
  },
];

const exhibitions = [
  { name: 'National Graphic Design Exhibition', meta: 'Selected / Finalist · China Artists Association · 2025' },
  { name: 'Tianjin Youth Art Season', meta: 'Selected work · Tianjin Academy of Fine Arts · 2025' },
  {
    name: 'Moments in Sound and Image — Tsinghua Alumni Boston Art Festival',
    meta: 'North America Federation of Tsinghua Alumni Association · 2025',
    link: 'https://www.tsinghua.org.cn/info/1013/41767.htm',
  },
  { name: 'Chinese Character Interactive Festival', meta: 'Macao · 2022' },
];

const awards = [
  {
    name: 'Shenzhen Global Design Award',
    meta: 'Excellence Award (Kunpeng Award) · Shenzhen Municipal Government · Shenzhen Innovation & Creative Design Development Office · 2024',
  },
  {
    name: 'BIAF Busan International Art Festival',
    meta: 'Silver Award · Busan Metropolitan City · BIAF Organizing Committee · 2024',
  },
  {
    name: 'Asia Vanguard Art and Design Competition (AVADC)',
    meta: 'First Prize · 2024',
  },
];

const activities = [
  {
    name: 'Tsinghua International Art & Design Education Conference',
    meta: 'Volunteer · Tsinghua University · 2023',
  },
  {
    name: 'GDC Show 2017 — Tell the Future',
    meta: 'Execution team · Tsinghua University · 2017',
    link: 'https://www.gdcaward.com/gdc-show-243.html?lang=cn',
  },
];

const photoStripImages = [1, 2, 3, 4, 5, 6].map((n) => `/img/strip/strip-${n}.jpg`);
---

<BaseLayout
  title="About Wang Yifan | AI Product Designer & Researcher"
  description="Wang Yifan is an AI product designer and researcher in Redmond, working across human–machine collaboration, visual systems, and cultural experience."
  ogType="profile"
  pageType="default"
  extraHead={breadcrumbJsonLd}
>
  <article class="about-page">
    <header class="about-hero">
      <h1>I bring research and visual thinking to AI product design.</h1>

      <div class="about-hero-copy">
        <p>
          I’m a product designer and researcher based in Redmond, Washington. I design AI products and visual
          systems that make emerging technology clearer, more useful, and more human.
        </p>
        <p>
          My practice connects product thinking, human–machine collaboration, and cultural visual systems—drawing
          on a PhD in Visual Communication and hands-on experience building digital products.
        </p>
      </div>

      <ul class="about-facts" aria-label="At a glance">
        <li>Product Designer &amp; Researcher</li>
        <li>PhD · Tsinghua University</li>
        <li>Redmond, WA</li>
      </ul>

      <div class="about-actions">
        <a class="about-button about-button--primary" href="/">View selected work <span aria-hidden="true">↗</span></a>
        <a class="about-button" href="mailto:vegdogzhenzhen@gmail.com">Email me <span aria-hidden="true">↗</span></a>
        <a class="about-text-link" href="https://www.linkedin.com/in/yifanwang-design" target="_blank" rel="noopener noreferrer">
          LinkedIn <span aria-hidden="true">↗</span>
        </a>
      </div>
    </header>

    <section class="about-section practice-section" aria-labelledby="practice-heading">
      <div class="section-intro">
        <p class="section-kicker">Practice</p>
        <h2 id="practice-heading">Curious by training, visual by instinct, systematic in practice.</h2>
      </div>

      <div class="practice-grid">
        {practice.map((item) => (
          <article class="practice-card">
            <h3>{item.name}</h3>
            <p>{item.detail}</p>
            <a href={item.href}>{item.linkLabel} <span aria-hidden="true">↗</span></a>
          </article>
        ))}
      </div>
    </section>

    <section class="about-photo-strip-section" aria-label="Scenes from Wang Yifan’s creative practice">
      <div class="about-photo-strip-window">
        <div class="about-photo-strip">
          <div class="about-photo-strip-set">
            {photoStripImages.map((src) => <img src={src} alt="" loading="lazy" />)}
          </div>
          <div class="about-photo-strip-set" aria-hidden="true">
            {photoStripImages.map((src) => <img src={src} alt="" loading="lazy" />)}
          </div>
        </div>
      </div>
    </section>

    <section class="about-section background-section" aria-labelledby="background-heading">
      <div class="section-intro section-intro--split">
        <div>
          <p class="section-kicker">Background</p>
          <h2 id="background-heading">A practice shaped across disciplines.</h2>
        </div>
        <p>
          My path moved from visual communication and cultural research into human–machine collaboration and AI
          products. That mix helps me see both the system behind an experience and the small visual details that
          make it feel approachable.
        </p>
      </div>

      <div class="background-grid">
        <section class="background-column" aria-labelledby="experience-heading">
          <h3 id="experience-heading">Selected Experience</h3>
          <ol class="timeline-list">
            {experience.map((item) => (
              <li>
                <div class="timeline-heading">
                  <h4>{item.title}</h4>
                  {item.period && <time>{item.period}</time>}
                </div>
                <p class="timeline-organization">{item.organization}</p>
                <p>{item.detail}</p>
              </li>
            ))}
          </ol>
        </section>

        <section class="background-column" aria-labelledby="education-heading">
          <h3 id="education-heading">Education</h3>
          <ol class="timeline-list">
            {education.map((item) => (
              <li>
                <div class="timeline-heading">
                  <h4>{item.degree}</h4>
                  <time>{item.period}</time>
                </div>
                <p class="timeline-organization">{item.school}</p>
                <p>{item.detail}</p>
              </li>
            ))}
          </ol>
        </section>
      </div>
    </section>

    <section class="about-section record-section" aria-labelledby="record-heading">
      <div class="section-intro section-intro--split">
        <div>
          <p class="section-kicker">Research record</p>
          <h2 id="record-heading">Writing, exhibitions, and recognition.</h2>
        </div>
        <p>
          A selected record of research and creative work across AI, design philosophy, and cultural visual systems.
        </p>
      </div>

      <section class="record-group record-group--publications" aria-labelledby="publications-heading">
        <h3 id="publications-heading">Publications</h3>
        <ol class="record-list record-list--numbered">
          {publications.map((item, index) => (
            <li>
              <span class="record-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h4>
                  {item.link
                    ? <a href={item.link} target="_blank" rel="noopener noreferrer">{item.name} <span aria-hidden="true">↗</span></a>
                    : item.name}
                </h4>
                <p>{item.meta}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <div class="record-grid">
        <section class="record-group" aria-labelledby="exhibitions-heading">
          <h3 id="exhibitions-heading">Exhibitions</h3>
          <ul class="record-list">
            {exhibitions.map((item) => (
              <li>
                <div>
                  <h4>
                    {item.link
                      ? <a href={item.link} target="_blank" rel="noopener noreferrer">{item.name} <span aria-hidden="true">↗</span></a>
                      : item.name}
                  </h4>
                  <p>{item.meta}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>

        <section class="record-group" aria-labelledby="awards-heading">
          <h3 id="awards-heading">Awards</h3>
          <ul class="record-list">
            {awards.map((item) => (
              <li>
                <div>
                  <h4>{item.name}</h4>
                  <p>{item.meta}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>

        <section class="record-group" aria-labelledby="conference-heading">
          <h3 id="conference-heading">Conference</h3>
          <ul class="record-list">
            {conferencePresentations.map((item) => (
              <li>
                <div>
                  <h4>{item.name}</h4>
                  <p>{item.meta}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>

        <section class="record-group" aria-labelledby="activities-heading">
          <h3 id="activities-heading">Activities</h3>
          <ul class="record-list">
            {activities.map((item) => (
              <li>
                <div>
                  <h4>
                    {item.link
                      ? <a href={item.link} target="_blank" rel="noopener noreferrer">{item.name} <span aria-hidden="true">↗</span></a>
                      : item.name}
                  </h4>
                  <p>{item.meta}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>
      </div>
    </section>

    <section class="about-cta" aria-labelledby="cta-heading">
      <div class="about-cta-dog"><DogHero /></div>
      <p class="section-kicker">Say hello</p>
      <h2 id="cta-heading">Let’s make complex technology feel more human.</h2>
      <div class="about-actions about-actions--centered">
        <a class="about-button about-button--primary" href="mailto:vegdogzhenzhen@gmail.com">Email me <span aria-hidden="true">↗</span></a>
        <a class="about-button" href="/">View work <span aria-hidden="true">↗</span></a>
      </div>
    </section>
  </article>
</BaseLayout>
