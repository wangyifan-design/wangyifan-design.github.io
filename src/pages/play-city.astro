---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlayCityBuilding from '../components/PlayCityBuilding.astro';
import { playItems } from '../data/play';
import '../styles/play-city.css';

const cityBuildings = [
  {
    id: 'building-one',
    name: 'Play City building one',
    items: playItems.slice(0, 9),
    variant: 'house',
    metaSide: 'right',
  },
  {
    id: 'building-two',
    name: 'Play City building two',
    items: [...playItems.slice(9, 13), ...playItems.slice(14, 18)],
    variant: 'tower',
    metaSide: 'alternate',
  },
  {
    id: 'building-three',
    name: 'Play City building three',
    items: [...playItems.slice(13, 14), ...playItems.slice(18)],
    variant: 'lab',
    metaSide: 'left',
  },
] as const;
---

<BaseLayout
  title="Play City Prototype | Wang Yifan Design"
  description="A prototype city made from Wang Yifan's books, posters, characters, and interactive experiments."
  ogImage="/img/play/zhenzhen-2025.jpg"
  pageType="play"
>
  <div class="play-city-page">
    <h1 class="visually-hidden">Play City</h1>

    <section class="city-skyline" aria-label="Play City skyline">
      {cityBuildings.map((building) => (
        <PlayCityBuilding
          id={building.id}
          name={building.name}
          items={building.items}
          variant={building.variant}
          metaSide={building.metaSide}
        />
      ))}
    </section>

  </div>

  <div id="lightbox" class="lightbox">
    <button type="button" class="lightbox-close" aria-label="Close image viewer">&times;</button>
    <button type="button" class="lightbox-nav lightbox-prev" aria-label="Previous image">‹</button>
    <button type="button" class="lightbox-nav lightbox-next" aria-label="Next image">›</button>
    <img id="lightbox-img" class="lightbox-content" alt="" />
  </div>
</BaseLayout>
