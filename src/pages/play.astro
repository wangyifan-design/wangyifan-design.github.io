---
import BaseLayout from '../layouts/BaseLayout.astro';
import { playItems } from '../data/play';
import '../styles/play.css';

const breadcrumbJsonLd = `<script type="application/ld+json">${JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://wangyifan-design.github.io/" },
    { "@type": "ListItem", "position": 2, "name": "Play", "item": "https://wangyifan-design.github.io/play/" }
  ]
})}<\/script>`;
---

<BaseLayout
  title="Playground Projects | Wang Yifan Design"
  description="Browse personal explorations by designer Wang Yifan, from illustrations and typography to branding experiments."
  ogImage="/img/play/zhenzhen-2025.jpg"
  pageType="play"
  extraHead={breadcrumbJsonLd}
>
  <section class="projects play">
    {playItems.map((item) => {
      // Items can be either a still image (.jpg/.png) or a short looping
      // video (.mp4 — replaces the original .gif files for ~80% size
      // savings while keeping the same visual feel).
      const isVideo = /\.(mp4|webm)$/i.test(item.image);
      return (
        <div class="project">
          {isVideo ? (
            <video
              class="project-image"
              src={item.image}
              autoplay muted loop playsinline
              aria-label={item.alt}
              preload="metadata"
            ></video>
          ) : (
            <img
              class="project-image"
              src={item.image}
              alt={item.alt}
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="project-labels">
            {item.labels.map((label) => <span>{label}</span>)}
          </div>
        </div>
      );
    })}
  </section>

  <!-- Lightbox container — opened by global script.js.
       Prev/next/close are wired up in initLightbox(). -->
  <div id="lightbox" class="lightbox">
    <button type="button" class="lightbox-close" aria-label="Close image viewer">&times;</button>
    <button type="button" class="lightbox-nav lightbox-prev" aria-label="Previous image">‹</button>
    <button type="button" class="lightbox-nav lightbox-next" aria-label="Next image">›</button>
    <img id="lightbox-img" class="lightbox-content" alt="" />
  </div>
</BaseLayout>
